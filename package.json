    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "db:seed": "node --env-file=.env scripts/seed.mjs",
    "db:migrate-legacy": "node --env-file=.env scripts/migrate-from-sqlserver.mjs"
  },
  "dependencies": {
    "@azure/storage-blob": "^12.32.0",
    "@sendgrid/mail": "^8.1.6",
    "drizzle-orm": "latest",
    "exifr": "^7.1.3",
    "jimp": "^1.6.1",
    "jose": "^6.2.3",
    "leaflet": "^1.9.4",
    "nuxt": "latest",
    "postgres": "latest",
    "twilio": "^6.0.2",
    "vue": "latest",
    "vue-router": "latest",
    "vuetify-nuxt-module": "latest"
  },
  "devDependencies": {
    "@types/leaflet": "^1.9.21",
    "drizzle-kit": "latest",
    "mssql": "^12.5.5",
    "sass-embedded": "latest"
  },
  "overrides": {
