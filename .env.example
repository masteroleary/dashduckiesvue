# Copy to .env for local development. Set the same vars in Railway → service → Variables.

# Postgres (Railway → your Postgres service → Variables → DATABASE_URL)
DATABASE_URL=postgresql://user:password@host:5432/dbname

# Auth (Phase 3) — generate a long random string
JWT_SECRET=change-me

# External services (Phase 3/6) — carried over from the old app
# SENDGRID_API_KEY=
# SENDGRID_FROM_EMAIL=info@dashduckies.com
# SENDGRID_FROM_NAME=Dash Duckies
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_VERIFY_SERVICE_SID=
# HERE_API_KEY=
# AZURE_STORAGE_CONNECTION_STRING=

# Legacy SQL Server migration (npm run db:migrate-legacy) — one of:
# OLD_SQLSERVER_URL=Server=host;Database=db;User Id=user;Password=pass;Encrypt=false
# OLD_SQLSERVER_HOST=
# OLD_SQLSERVER_DB=
# OLD_SQLSERVER_USER=
# OLD_SQLSERVER_PASSWORD=
