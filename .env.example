# Copy to .env for local development. Set the same vars in Railway → service → Variables.

# Postgres (Railway → your Postgres service → Variables → DATABASE_URL)
DATABASE_URL=postgresql://user:password@host:5432/dbname

# Auth (Phase 3) — generate a long random string
JWT_SECRET=change-me

# External services (Phase 3/6) — carried over from the old app
